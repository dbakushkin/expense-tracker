{
  "name": "@expence-tracker/api",
  "version": "0.0.0",
  "private": true,
  "description": "Expense tracker API (NestJS)",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prisma": "prisma",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@expence-tracker/shared-types": "workspace:*",
    "@nestjs/common": "^10",
    "@nestjs/config": "^3",
    "@nestjs/core": "^10",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^10",
    "@nestjs/passport": "^10",
    "@nestjs/platform-express": "^10",
    "@prisma/client": "^5",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7"
  },
  "devDependencies": {
    "@expence-tracker/eslint-config": "workspace:*",
    "@expence-tracker/tsconfig": "workspace:*",
    "@nestjs/cli": "^10",
    "@nestjs/schematics": "^10",
    "@nestjs/testing": "^10",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4",
    "@types/jest": "^29",
    "@types/node": "^20",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6",
    "eslint": "^8.57.0",
    "jest": "^29",
    "prisma": "^5",
    "source-map-support": "^0.5",
    "supertest": "^7",
    "ts-jest": "^29",
    "ts-loader": "^9",
    "ts-node": "^10",
    "tsconfig-paths": "^4",
    "typescript": "^5.4"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
